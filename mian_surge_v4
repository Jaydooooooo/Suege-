#!/bin/bash

set -e

echo "=========================================="
echo "  Docker 安装 Snell v5 + Shadow-TLS v3"
echo "=========================================="

# ─── 检测架构 ───────────────────────────────
ARCH=$(uname -m)
case $ARCH in
    x86_64)  SNELL_ARCH="amd64"   ; TLS_ARCH="x86_64-unknown-linux-musl"  ;;
    aarch64) SNELL_ARCH="aarch64" ; TLS_ARCH="aarch64-unknown-linux-musl" ;;
    armv7l)  SNELL_ARCH="armv7l"  ; TLS_ARCH="armv7-unknown-linux-musleabihf" ;;
    i386|i686) SNELL_ARCH="i386"  ; TLS_ARCH="i686-unknown-linux-musl"    ;;
    *)
        echo "❌ 不支持的架构: $ARCH"
        exit 1
        ;;
esac

SNELL_VERSION="v5.0.1"
SNELL_URL="https://dl.nssurge.com/snell/snell-server-${SNELL_VERSION}-linux-${SNELL_ARCH}.zip"

# Shadow-TLS 最新稳定版
TLS_VERSION="v0.2.25"
TLS_URL="https://github.com/ihciah/shadow-tls/releases/download/${TLS_VERSION}/shadow-tls-${TLS_ARCH}"

echo "📦 架构: $ARCH"
echo "📦 Snell  : snell-server-${SNELL_VERSION}-linux-${SNELL_ARCH}.zip"
echo "📦 Shadow-TLS: shadow-tls-${TLS_ARCH} ${TLS_VERSION}"

# ─── 检查 / 安装 Docker ────────────────────
if ! command -v docker &>/dev/null; then
    echo "🐳 Docker 未安装，正在自动安装..."
    apt-get update -qq
    curl -fsSL https://get.docker.com | bash
    systemctl enable docker
    systemctl start docker
    echo "✅ Docker 安装完成"
else
    echo "✅ Docker 已安装: $(docker --version)"
fi

# ─── 停止 / 清理旧容器 ────────────────────
for CNAME in snell-v5-tls shadow-tls-v5; do
    if docker ps -a --format '{{.Names}}' | grep -q "^${CNAME}$"; then
        echo "🔄 清理旧容器: $CNAME"
        docker stop "$CNAME" 2>/dev/null || true
        docker rm   "$CNAME" 2>/dev/null || true
    fi
done

# ─── 生成随机参数 ─────────────────────────
SNELL_PSK=$(openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 24)
TLS_PSK=$(openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 24)
SNELL_PORT=$(shuf -i 20000-40000 -n 1)   # Snell 内部端口（容器内）
TLS_PORT=$(shuf -i 40001-60000 -n 1)     # Shadow-TLS 对外端口

# 备用随机方案
if [ -z "$SNELL_PSK" ]; then
    SNELL_PSK=$(cat /dev/urandom | tr -dc 'A-Za-z0-9' | head -c 24)
    TLS_PSK=$(cat /dev/urandom | tr -dc 'A-Za-z0-9' | head -c 24)
fi

# Shadow-TLS 伪装 SNI（使用知名域名，看起来像正常 TLS 流量）
TLS_SNI="gateway.icloud.com"

echo ""
echo "🔑 Snell PSK       : $SNELL_PSK"
echo "🔑 Shadow-TLS PSK  : $TLS_PSK"
echo "🔌 Snell 内部端口  : $SNELL_PORT"
echo "🔌 对外监听端口    : $TLS_PORT"
echo "🌐 伪装 SNI        : $TLS_SNI"

# ─── 创建工作目录 ────────────────────────
WORKDIR="/opt/snell-v5-tls"
mkdir -p "$WORKDIR"

# ─── 创建 Docker 网络（Snell 与 Shadow-TLS 通信用）────
if ! docker network ls --format '{{.Name}}' | grep -q '^snell-net$'; then
    docker network create snell-net
    echo "🔗 创建 Docker 网络: snell-net"
fi

# ─── 写入 Snell 配置文件 ─────────────────
cat > "$WORKDIR/snell-server.conf" << CONF
[snell-server]
listen = 0.0.0.0:${SNELL_PORT}
psk = ${SNELL_PSK}
ipv6 = false
CONF

echo "📝 Snell 配置已写入 $WORKDIR/snell-server.conf"

# ─── 构建 Snell v5 Docker 镜像 ───────────
cat > "$WORKDIR/Dockerfile.snell" << DOCKERFILE
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends wget unzip ca-certificates && \
    rm -rf /var/lib/apt/lists/*

ARG SNELL_URL
RUN wget -q "${SNELL_URL}" -O /tmp/snell.zip && \
    unzip -q /tmp/snell.zip -d /usr/local/bin/ && \
    chmod +x /usr/local/bin/snell-server && \
    rm /tmp/snell.zip

RUN mkdir -p /etc/snell

EXPOSE ${SNELL_PORT}/tcp
EXPOSE ${SNELL_PORT}/udp

CMD ["/usr/local/bin/snell-server", "-c", "/etc/snell/snell-server.conf"]
DOCKERFILE

echo "🔨 正在构建 Snell v5 镜像..."
docker build \
    --build-arg SNELL_URL="$SNELL_URL" \
    -f "$WORKDIR/Dockerfile.snell" \
    -t snell-v5-tls-image \
    "$WORKDIR"

# ─── 构建 Shadow-TLS Docker 镜像 ─────────
cat > "$WORKDIR/Dockerfile.tls" << DOCKERFILE
FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends wget ca-certificates && \
    rm -rf /var/lib/apt/lists/*

ARG TLS_URL
RUN wget -q "${TLS_URL}" -O /usr/local/bin/shadow-tls && \
    chmod +x /usr/local/bin/shadow-tls

EXPOSE ${TLS_PORT}/tcp

ENTRYPOINT ["/usr/local/bin/shadow-tls"]
DOCKERFILE

echo "🔨 正在构建 Shadow-TLS 镜像..."
docker build \
    --build-arg TLS_URL="$TLS_URL" \
    -f "$WORKDIR/Dockerfile.tls" \
    -t shadow-tls-v3-image \
    "$WORKDIR"

# ─── 启动 Snell v5 容器（仅内部网络）────
echo "🚀 正在启动 Snell v5 容器..."
docker run -d \
    --name snell-v5-tls \
    --restart always \
    --network snell-net \
    -v "$WORKDIR/snell-server.conf:/etc/snell/snell-server.conf:ro" \
    snell-v5-tls-image

# ─── 启动 Shadow-TLS v3 容器 ─────────────
echo "🚀 正在启动 Shadow-TLS v3 容器..."
docker run -d \
    --name shadow-tls-v5 \
    --restart always \
    --network snell-net \
    -p "${TLS_PORT}:${TLS_PORT}/tcp" \
    shadow-tls-v3-image \
    server \
    --v3 \
    --listen "0.0.0.0:${TLS_PORT}" \
    --server "snell-v5-tls:${SNELL_PORT}" \
    --tls "${TLS_SNI}" \
    --password "${TLS_PSK}"

# ─── 获取服务器公网 IP ──────────────────
echo "🌐 正在获取服务器公网 IP..."
SERVER_IP=$(curl -s4 --max-time 5 ifconfig.me 2>/dev/null)
if [ -z "$SERVER_IP" ]; then
    SERVER_IP=$(curl -s4 --max-time 5 ip.sb 2>/dev/null)
fi
if [ -z "$SERVER_IP" ]; then
    SERVER_IP=$(curl -s4 --max-time 5 api.ipify.org 2>/dev/null)
fi
if [ -z "$SERVER_IP" ]; then
    SERVER_IP="YOUR_SERVER_IP"
    echo "⚠️  无法自动获取公网IP，请手动替换配置中的 YOUR_SERVER_IP"
fi

# ─── 保存配置信息 ────────────────────────
INFO_FILE="$WORKDIR/surge-config.txt"
cat > "$INFO_FILE" << INFO
==========================================
Snell v5 + Shadow-TLS v3 安装信息
==========================================
服务器 IP         : ${SERVER_IP}
对外端口(TLS)     : ${TLS_PORT}
Snell 内部端口    : ${SNELL_PORT}
Snell PSK         : ${SNELL_PSK}
Shadow-TLS PSK    : ${TLS_PSK}
Shadow-TLS SNI    : ${TLS_SNI}

Surge 配置行（复制此行）：
Snell-V5-TLS = snell, ${SERVER_IP}, ${TLS_PORT}, psk=${SNELL_PSK}, version=5, reuse=true, tfo=true, shadow-tls-password=${TLS_PSK}, shadow-tls-sni=${TLS_SNI}, shadow-tls-version=3
==========================================
INFO

# ─── 打印结果 ────────────────────────────
echo ""
echo "=========================================="
echo "✅  Snell v5 + Shadow-TLS v3 安装完成！"
echo "=========================================="
echo ""
echo "  服务器 IP         : ${SERVER_IP}"
echo "  对外端口(TLS)     : ${TLS_PORT}"
echo "  Snell 内部端口    : ${SNELL_PORT}"
echo "  Snell PSK         : ${SNELL_PSK}"
echo "  Shadow-TLS PSK    : ${TLS_PSK}"
echo "  伪装 SNI          : ${TLS_SNI}"
echo ""
echo "📋 Surge 配置（复制以下一行到 Surge [Proxy] 节）："
echo ""
echo "  Snell-V5-TLS = snell, ${SERVER_IP}, ${TLS_PORT}, psk=${SNELL_PSK}, version=5, reuse=true, tfo=true, shadow-tls-password=${TLS_PSK}, shadow-tls-sni=${TLS_SNI}, shadow-tls-version=3"
echo ""
echo "📁 配置信息已保存至: $INFO_FILE"
echo ""
echo "🔧 常用命令："
echo "  查看容器状态 : docker ps | grep -E 'snell-v5-tls|shadow-tls-v5'"
echo "  Snell 日志   : docker logs snell-v5-tls"
echo "  TLS   日志   : docker logs shadow-tls-v5"
echo "  停止全部     : docker stop snell-v5-tls shadow-tls-v5"
echo "  卸载全部     : docker stop snell-v5-tls shadow-tls-v5 && docker rm snell-v5-tls shadow-tls-v5 && docker network rm snell-net"
echo "=========================================="
